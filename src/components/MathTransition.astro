<!--
  MathTransition — Fourier synthesis driven by scroll position.
  The waves only move as the user scrolls through the element,
  freezing when the page is still.
-->
<div class="relative w-full overflow-hidden" style="height: 120px;">
  <canvas
    id="math-transition"
    aria-hidden="true"
    class="absolute inset-0 w-full h-full"
  ></canvas>

  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
    <span
      class="font-mono text-phi-xs text-copy"
      style="opacity: 0.15; letter-spacing: 0.18em;"
    >
      f(x,t) = ∑ aₙ · sin(φⁿkx − ωt)
    </span>
  </div>
</div>

<script>
  const PHI    = (1 + Math.sqrt(5)) / 2;
  const canvas = document.getElementById('math-transition') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;

  const WAVES = [
    { n: 0, amp: 14, color: '#F97316', alpha: 0.80, speed: 0.38 },
    { n: 1, amp:  8, color: '#0EA5E9', alpha: 0.65, speed: 0.62 },
    { n: 2, amp:  5, color: '#8A8A96', alpha: 0.45, speed: 1.00 },
  ];

  function resize() {
    const dpr     = window.devicePixelRatio || 1;
    canvas.width  = canvas.offsetWidth  * dpr;
    canvas.height = canvas.offsetHeight * dpr;
    ctx.scale(dpr, dpr);
  }

  function drawFrame(phase: number) {
    const w  = canvas.offsetWidth;
    const h  = canvas.offsetHeight;
    const cy = h / 2;
    const k0 = (2.5 * 2 * Math.PI) / w;

    ctx.clearRect(0, 0, w, h);

    for (const wave of WAVES) {
      const k = k0 * Math.pow(PHI, wave.n);
      ctx.save();
      ctx.globalAlpha = wave.alpha;
      ctx.strokeStyle = wave.color;
      ctx.lineWidth   = 1.2;
      ctx.beginPath();
      for (let x = 0; x <= w; x++) {
        const y = cy + Math.sin(k * x - wave.speed * phase) * wave.amp;
        x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();
      ctx.restore();
    }

    ctx.save();
    ctx.globalAlpha = 0.92;
    ctx.strokeStyle = '#F0F0F4';
    ctx.lineWidth   = 2;
    ctx.beginPath();
    for (let x = 0; x <= w; x++) {
      const y = cy + WAVES.reduce((sum, wave) => {
        const k = k0 * Math.pow(PHI, wave.n);
        return sum + Math.sin(k * x - wave.speed * phase) * wave.amp;
      }, 0);
      x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();
    ctx.restore();

    // edge fades
    const bg  = '#0D0D0F';
    const bg0 = 'rgba(13,13,15,0)';
    const ew  = w * 0.07;
    const eh  = h * 0.22;

    [[0, ew, true, false], [w - ew, w, false, false]].forEach(([x0, x1, l]) => {
      const g = ctx.createLinearGradient(x0 as number, 0, x1 as number, 0);
      g.addColorStop(0, l ? bg : bg0);
      g.addColorStop(1, l ? bg0 : bg);
      ctx.fillStyle = g;
      ctx.fillRect(x0 as number, 0, (x1 as number) - (x0 as number), h);
    });

    [[0, eh, true], [h - eh, h, false]].forEach(([y0, y1, top]) => {
      const g = ctx.createLinearGradient(0, y0 as number, 0, y1 as number);
      g.addColorStop(0, top ? bg : bg0);
      g.addColorStop(1, top ? bg0 : bg);
      ctx.fillStyle = g;
      ctx.fillRect(0, y0 as number, w, (y1 as number) - (y0 as number));
    });
  }

  // ── Scroll-driven phase ───────────────────────
  // progress: 0 when element enters viewport bottom → 1 when it leaves viewport top
  function scrollProgress(): number {
    const rect  = canvas.getBoundingClientRect();
    const viewH = window.innerHeight;
    return (viewH - rect.top) / (viewH + rect.height);
  }

  function update() {
    const p     = Math.max(0, Math.min(1, scrollProgress()));
    // sweep 3 full wave cycles (6π) as user scrolls through
    drawFrame(p * Math.PI * 6);
  }

  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', () => { resize(); update(); });

  resize();
  update(); // initial frame at current scroll position
</script>