---
const links = [
  { href: '/',          label: 'home' },
  { href: '/blog',      label: 'blog' },
  { href: '/portfolio', label: 'portfolio' },
  { href: '/about',     label: 'about' },
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  class="border-b border-line px-4 md:px-14 sticky top-0 z-50 backdrop-blur-sm"
  style="background-color: rgba(13, 13, 15, 0.88);"
>
  <nav class="max-w-content mx-auto h-16 flex items-center justify-between">
    <a
      href="/"
      class="font-mono text-phi-base font-medium text-copy hover:text-orange transition-colors"
    >
      rt<span class="text-orange">.</span>
    </a>

    <ul class="flex items-center gap-4 md:gap-8 list-none">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-mono text-phi-xs uppercase tracking-widest transition-colors',
              isActive(link.href)
                ? 'text-orange'
                : 'text-muted hover:text-copy',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>