---
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';
import Nav from './Nav.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Applied mathematics for multimedia, deep learning, and web development.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} — Rafael Torres`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Rafael Torres</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer class="border-t border-line mt-32 py-8 px-4 md:px-14">
      <div class="max-w-content mx-auto flex items-center justify-between">
        <span class="font-mono text-phi-xs text-muted">
          © {new Date().getFullYear()} Rafael Torres
        </span>
        <span class="font-mono text-phi-xs text-muted">
          Code: MIT · Content: CC BY 4.0
        </span>
      </div>
    </footer>
  </body>
</html>