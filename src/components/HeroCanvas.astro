<canvas
  id="hero-canvas"
  aria-hidden="true"
  class="absolute inset-0 w-full h-full"
></canvas>

<script>
  const N          = 90;
  const MAX_EDGE_D = 165;
  const REPEL_R    = 140;
  const REPEL_STR  = 7;
  const LERP       = 0.045;

  interface Node {
    ox: number; oy: number;
    x:  number; y:  number;
    vx: number; vy: number;
    r:  number;
  }

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;
  let nodes: Node[] = [];
  let mx = -9999, my = -9999;
  let raf: number;

  function buildNodes() {
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;
    nodes = Array.from({ length: N }, () => {
      const x = Math.random() * w;
      const y = Math.random() * h;
      return { ox: x, oy: y, x, y, vx: 0, vy: 0, r: 2 + Math.random() * 2 };
    });
  }

  function tick() {
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;
    if (w === 0 || h === 0) { raf = requestAnimationFrame(tick); return; }

    ctx.clearRect(0, 0, w, h);

    // physics
    for (const n of nodes) {
      const dx = n.x - mx;
      const dy = n.y - my;
      const d  = Math.hypot(dx, dy) || 1;
      if (d < REPEL_R) {
        const f = Math.pow(1 - d / REPEL_R, 2) * REPEL_STR;
        n.vx += (dx / d) * f;
        n.vy += (dy / d) * f;
      }
      n.vx *= 0.84; n.vy *= 0.84;
      n.x  += n.vx;  n.y  += n.vy;
      n.x  += (n.ox - n.x) * LERP;
      n.y  += (n.oy - n.y) * LERP;
    }

    // edges first (behind nodes)
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const a  = nodes[i];
        const b  = nodes[j];
        const d  = Math.hypot(a.x - b.x, a.y - b.y);
        if (d < MAX_EDGE_D) {
          ctx.save();
          ctx.globalAlpha = (1 - d / MAX_EDGE_D) * 0.32;
          ctx.strokeStyle = '#F97316';
          ctx.lineWidth   = 1.4;   // mais grosso
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.stroke();
          ctx.restore();
        }
      }
    }

    // nodes on top — halo escuro separa do laranja
    for (const n of nodes) {
      const near = Math.hypot(n.x - mx, n.y - my) < REPEL_R;

      // halo: disco surface-color ao redor do nó
      ctx.save();
      ctx.globalAlpha = 1;
      ctx.fillStyle   = '#0D0D0F';
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r + 2, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();

      // nó
      ctx.save();
      ctx.globalAlpha = near ? 0.95 : 0.65;
      ctx.fillStyle   = near ? '#F97316' : '#0EA5E9';
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    raf = requestAnimationFrame(tick);
  }

  function resize() {
    const dpr     = window.devicePixelRatio || 1;
    canvas.width  = canvas.offsetWidth  * dpr;
    canvas.height = canvas.offsetHeight * dpr;
    ctx.scale(dpr, dpr);
    buildNodes();
  }

  canvas.addEventListener('pointermove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mx = e.clientX - rect.left;
    my = e.clientY - rect.top;
  });
  canvas.addEventListener('pointerleave', () => { mx = -9999; my = -9999; });

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { cancelAnimationFrame(raf); resize(); tick(); }, 100);
  });

  resize();
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) tick();
</script>