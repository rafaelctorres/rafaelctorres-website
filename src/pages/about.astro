---
import Layout from '../components/Layout.astro';
import VogelCanvas from '../components/VogelCanvas.astro';
---

<Layout
  title="About"
  description="Rafael Torres — graduate in Systems and Digital Media, UFC."
>

  <!-- ── Spiral hero ────────────────────────────── -->
  <section class="relative min-h-[60vh] md:h-[28rem] flex items-center justify-center overflow-hidden px-4 md:px-14 py-16 w-full">
    
    <div class="relative z-10 flex flex-col md:flex-row items-center justify-center gap-10 md:gap-20 w-full max-w-5xl mx-auto">
      
      <!-- Container da Espiral e da Foto -->
      <div class="relative flex items-center justify-center w-80 h-80 md:w-[28rem] md:h-[28rem] flex-shrink-0">
        
        <!-- Espiral por trás -->
        <div class="absolute inset-0 z-0 flex items-center justify-center">
          <VogelCanvas />
        </div>
        
        <!-- Foto Circular sem borda demarcada -->
        <img 
          src="/rafael.png" 
          alt="Rafael Torres" 
          class="relative z-10 w-48 h-48 md:w-60 md:h-60 object-cover rounded-full shadow-2xl"
        />
      </div>

      <!-- Texto ao lado -->
      <div class="relative z-10 text-center md:text-left">
        <p class="font-mono text-phi-xs text-orange uppercase tracking-widest mb-3">
          Systems and Digital Media · UFC · 2026
        </p>
        <h1 class="font-sans text-phi-lg md:text-phi-xl font-bold text-copy leading-tight">
          Rafael Torres
        </h1>
      </div>
      
    </div>

    <div
      class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none z-20"
      style="background: linear-gradient(to bottom, transparent, #0D0D0F);"
    ></div>
  </section>

  <!-- ── Bio Centralizada Forçada ───────────────── -->
  <div class="w-full flex justify-center px-4 md:px-14 py-16 md:py-24">
    <div class="w-full max-w-3xl flex flex-col items-center text-center space-y-12">
      
      <!-- Parágrafos de Texto -->
      <div class="space-y-6 flex flex-col items-center">
        <p class="font-sans text-phi-md text-copy leading-relaxed max-w-2xl">
          Graduate in Sistemas e Mídias Digitais from Universidade Federal do Ceará (UFC),
          Fortaleza, Brasil.
        </p>

        <p class="font-sans text-phi-base text-muted leading-relaxed max-w-2xl">
          I am interested in problems where mathematics and computation meet visual and
          audio media: how signals encode structure, how geometry shapes perception,
          how models learn to see. I document that process here.
        </p>
      </div>

      <!-- Linha sutil de separação -->
      <div class="border-t border-line/30 w-16 pt-4"></div>

      <!-- Metadados Centralizados em Grid -->
      <div class="w-full grid sm:grid-cols-3 gap-10 text-center">
        
        <!-- Focus -->
        <div class="flex flex-col items-center space-y-3">
          <p class="font-mono text-phi-xs text-muted uppercase tracking-widest">focus</p>
          <ul class="flex flex-col items-center space-y-1">
            {['Applied Math for Multimedia', 'Deep Learning', 'Web Development'].map(item => (
              <li class="font-sans text-phi-sm text-copy">{item}</li>
            ))}
          </ul>
        </div>

        <!-- Education -->
        <div class="flex flex-col items-center space-y-2">
          <p class="font-mono text-phi-xs text-muted uppercase tracking-widest">education</p>
          <p class="font-sans text-phi-sm text-copy">Sistemas e Mídias Digitais</p>
          <p class="font-mono text-phi-xs text-muted">UFC · 2026</p>
        </div>

        <!-- Links -->
        <div class="flex flex-col items-center space-y-2">
          <p class="font-mono text-phi-xs text-muted uppercase tracking-widest">links</p>
          <ul class="flex flex-col items-center space-y-2">
            <li>
              <a href="https://github.com/rafaelctorres" target="_blank" rel="noopener noreferrer"
                class="font-mono text-phi-xs text-orange hover:text-orange-dim transition-colors">
                github →
              </a>
            </li>
            <li>
              <a href="https://linkedin.com/rafaelctorres" class="font-mono text-phi-xs text-orange hover:text-orange-dim transition-colors">
                linkedin →
              </a>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </div>

</Layout>