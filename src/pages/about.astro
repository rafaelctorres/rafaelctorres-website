---
import Layout from '../components/Layout.astro';
import VogelCanvas from '../components/VogelCanvas.astro';
---

<Layout
  title="About"
  description="Rafael Torres — graduate in Sistemas e Mídias Digitais, UFC."
>

  <!-- ── Spiral hero ────────────────────────────── -->
  <section class="relative h-96 flex items-center justify-center overflow-hidden">
    <VogelCanvas />
    <div class="relative z-10 text-center">
      <p class="font-mono text-phi-xs text-orange uppercase tracking-widest mb-3">
        Sistemas e Mídias Digitais · UFC · 2026
      </p>
      <h1 class="font-sans text-phi-lg md:text-phi-xl font-bold text-copy">
        Rafael Torres
      </h1>
    </div>
    <div
      class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
      style="background: linear-gradient(to bottom, transparent, #0D0D0F);"
    ></div>
  </section>

  <!-- ── Bio ───────────────────────────────────── -->
  <div class="px-4 md:px-14 py-24">
    <div class="max-w-content mx-auto">
      <div class="grid md:grid-cols-3 gap-12 md:gap-16">

        <div class="md:col-span-2 space-y-6">
          <p class="font-sans text-phi-md text-copy leading-relaxed">
            Graduate in Sistemas e Mídias Digitais from Universidade Federal do Ceará (UFC),
            Fortaleza, Brasil.
          </p>
          <p class="font-sans text-phi-base text-muted leading-relaxed">
            My undergraduate thesis integrated PyAFAR — a facial action unit detection library —
            into a web application with an interactive dashboard, combining computer vision,
            human-computer interaction, and software engineering.
          </p>
          <p class="font-sans text-phi-base text-muted leading-relaxed">
            I am interested in problems where mathematics and computation meet visual and
            audio media: how signals encode structure, how geometry shapes perception,
            how models learn to see. I document that process here.
          </p>
        </div>

        <aside class="space-y-10">
          <div>
            <p class="font-mono text-phi-xs text-muted uppercase tracking-widest mb-4">focus</p>
            <ul class="space-y-2">
              {['Applied Math for Multimedia', 'Deep Learning', 'Web Development'].map(item => (
                <li class="font-sans text-phi-sm text-copy">{item}</li>
              ))}
            </ul>
          </div>

          <div>
            <p class="font-mono text-phi-xs text-muted uppercase tracking-widest mb-4">education</p>
            <p class="font-sans text-phi-sm text-copy">Sistemas e Mídias Digitais</p>
            <p class="font-mono text-phi-xs text-muted mt-1">UFC · 2026</p>
          </div>

          <div>
            <p class="font-mono text-phi-xs text-muted uppercase tracking-widest mb-4">links</p>
            <ul class="space-y-3">
              <li>
                <a href="https://github.com/rafaelctorres" target="_blank" rel="noopener noreferrer"
                  class="font-mono text-phi-xs text-orange hover:text-orange-dim transition-colors">
                  github →
                </a>
              </li>
              <li>
                <a href="#" class="font-mono text-phi-xs text-orange hover:text-orange-dim transition-colors">
                  linkedin →
                </a>
              </li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </div>

</Layout>