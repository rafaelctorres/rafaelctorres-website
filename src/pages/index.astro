---
import Layout from '../components/Layout.astro';
import HeroCanvas from '../components/HeroCanvas.astro';
import { getCollection } from 'astro:content';

// Lógica de busca dos dados [cite: 1, 2, 3]
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection('portfolio', ({ data }) => data.featured))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Home">

  <section class="relative min-h-screen flex items-center justify-center">
    <HeroCanvas />

    <div class="relative z-10 flex flex-col items-center text-center px-4 py-24 gap-y-8">
      <p class="font-mono text-phi-xs text-orange uppercase tracking-widest">
        Fortaleza, Brasil
      </p>
      <h1 class="font-sans text-phi-lg md:text-phi-xl font-bold text-copy leading-none">
        Rafael C. Torres
      </h1>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href="/portfolio"
          class="font-mono text-phi-xs uppercase tracking-widest border border-orange text-orange px-6 py-3 hover:bg-orange hover:text-surface transition-colors">
          view work
        </a>
        <a href="/blog"
          class="font-mono text-phi-xs uppercase tracking-widest border border-line text-muted px-6 py-3 hover:border-copy hover:text-copy transition-colors">
          read blog
        </a>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
      style="background: linear-gradient(to bottom, transparent, #0D0D0F);"></div>
  </section>

  <!-- Seção "focus" reformulada com flexbox para centralização perfeita -->
  <section class="px-4 md:px-14 pt-12 pb-24">
    <div class="text-center">
      <p class="font-mono text-phi-xs text-muted uppercase tracking-widest mb-10">focus</p>
      <!-- Container flex com wrap e centralização -->
      <div class="flex flex-wrap justify-center gap-6">
        {[
          { n: '01', label: 'Applied Mathematics for Multimedia',
            desc: 'Signal processing, spectral analysis, geometric algebra, and the mathematical foundations of visual and audio media.'
          },
          { n: '02', label: 'Deep Learning',
            desc: 'Computer vision, facial action unit detection, model evaluation pipelines, and applied machine learning research.'
          },
          { n: '03', label: 'Web Development',
            desc: 'WebGL, real-time rendering, interactive systems, and creative tooling — interfaces that demonstrate ideas directly.'
          },
        ].map(({ n, label, desc }) => (
          // Comentário JavaScript – ou remova esta linha
          <div class="border border-line p-8 hover:border-orange transition-colors group text-center w-full max-w-sm flex-1 min-w-[250px]">
            <span class="font-mono text-phi-xs text-orange block mb-4">{n}</span>
            <h2 class="font-sans text-phi-base font-semibold text-copy mb-3 group-hover:text-orange transition-colors">{label}</h2>
            <p class="font-sans text-phi-sm text-muted leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="px-4 md:px-14 py-16 border-t border-line">
      <div class="max-w-content mx-auto">
        <p class="font-mono text-phi-xs text-muted uppercase tracking-widest mb-8">recent posts</p>
        <ul>
          {posts.map(post => (
            <li>
              <a href={`/blog/${post.id}`}
                class="flex items-center gap-6 py-5 border-b border-line hover:border-orange group transition-colors">
                <span class="font-mono text-phi-xs text-muted shrink-0 w-24">
                  {post.data.date.toISOString().slice(0, 10)}
                </span>
                <span class="font-sans text-phi-base text-copy group-hover:text-orange transition-colors flex-1">
                  {post.data.title}
                </span>
                <span class="font-mono text-phi-xs text-orange opacity-0 group-hover:opacity-100 transition-opacity">→</span>
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="font-mono text-phi-xs text-muted hover:text-orange transition-colors mt-8 inline-block">
          all posts →
        </a>
      </div>
    </section>
  )}

  {projects.length > 0 && (
    <section class="px-4 md:px-14 py-16 border-t border-line">
      <div class="max-w-content mx-auto">
        <p class="font-mono text-phi-xs text-muted uppercase tracking-widest mb-8">featured work</p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map(project => (
            <a href={`/portfolio/${project.id}`}
              class="border border-line p-6 hover:border-orange transition-colors group block">
              <h3 class="font-sans text-phi-base font-semibold text-copy mb-2 group-hover:text-orange transition-colors">
                {project.data.title}
              </h3>
              <p class="font-sans text-phi-sm text-muted mb-4 leading-relaxed">{project.data.description}</p>
              <div class="flex flex-wrap gap-3">
                {project.data.tags.map(tag => (
                  <span class="font-mono text-phi-xs text-blue">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
        <a href="/portfolio" class="font-mono text-phi-xs text-muted hover:text-orange transition-colors mt-8 inline-block">
          all projects →
        </a>
      </div>
    </section>
  )}

</Layout>