---
import Layout from '../../components/Layout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('portfolio'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Portfolio" description="Projects in applied mathematics for multimedia, deep learning, and web development.">
  <div class="px-4 md:px-14 py-24">
    <div class="max-w-content mx-auto">
      <p class="font-mono text-phi-xs text-orange uppercase tracking-widest mb-4">work</p>
      <h1 class="font-sans text-phi-md md:text-phi-lg font-bold text-copy mb-16">Portfolio</h1>

      {projects.length === 0 ? (
        <p class="font-mono text-phi-sm text-muted">No projects here yet. Coming soon. Meanwhile, my work is available on my <a href="https://linkedin.com/rafaelctorres" class="font-mono text-phi-xs text-orange hover:text-orange-dim transition-colors">
                linkedin
              </a></p>
      ) : (
        <div class="grid md:grid-cols-2 gap-6">
          {projects.map(project => (
            <a href={`/portfolio/${project.id}`}
              class="border border-line p-8 hover:border-orange transition-colors group block">
              <div class="flex items-start justify-between gap-4 mb-4">
                <h2 class="font-sans text-phi-md font-semibold text-copy group-hover:text-orange transition-colors">
                  {project.data.title}
                </h2>
                <span class="font-mono text-phi-xs text-muted shrink-0">
                  {project.data.date.toISOString().slice(0, 7)}
                </span>
              </div>
              <p class="font-sans text-phi-sm text-muted mb-6 leading-relaxed">{project.data.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {project.data.stack.map(item => (
                  <span class="font-mono text-phi-xs text-muted border border-line px-2 py-1">{item}</span>
                ))}
              </div>
              <div class="flex flex-wrap gap-3">
                {project.data.tags.map(tag => (
                  <span class="font-mono text-phi-xs text-blue">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>