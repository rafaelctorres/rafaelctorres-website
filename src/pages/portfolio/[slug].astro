---
import Layout from '../../components/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects.map(project => ({
    params: { slug: project.id },
    props:  { project },
  }));
}

interface Props {
  project: CollectionEntry<'portfolio'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.title} description={project.data.description}>
  <article class="px-4 md:px-14 py-24">
    <div class="max-w-content mx-auto">
      <a href="/portfolio" class="font-mono text-phi-xs text-muted hover:text-orange transition-colors mb-12 inline-block">
        ← back to portfolio
      </a>
      <header class="mb-16">
        <p class="font-mono text-phi-xs text-muted mb-4">{project.data.date.toISOString().slice(0, 7)}</p>
        <h1 class="font-sans text-phi-md md:text-phi-lg font-bold text-copy mb-4">{project.data.title}</h1>
        <p class="font-sans text-phi-base text-muted mb-8">{project.data.description}</p>
        <div class="flex flex-wrap items-center gap-4">
          <div class="flex flex-wrap gap-2">
            {project.data.stack.map(item => (
              <span class="font-mono text-phi-xs text-muted border border-line px-2 py-1">{item}</span>
            ))}
          </div>
          <div class="flex gap-6 ml-auto">
            {project.data.repo && (
              <a href={project.data.repo} target="_blank" rel="noopener noreferrer"
                class="font-mono text-phi-xs text-orange hover:text-orange-dim transition-colors">repo →</a>
            )}
            {project.data.live && (
              <a href={project.data.live} target="_blank" rel="noopener noreferrer"
                class="font-mono text-phi-xs text-blue hover:text-blue-dim transition-colors">live →</a>
            )}
          </div>
        </div>
      </header>
      <div class="prose"><Content /></div>
    </div>
  </article>
</Layout>